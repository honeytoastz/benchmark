<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Laptop Benchmark 2024–2026</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Rajdhani:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{--bg:#0c0c0e;--bg1:#111114;--bg2:#18181c;--bg3:#222228;--line:rgba(255,255,255,0.06);--line2:rgba(200,169,110,0.15);--text:#f5f5f0;--muted:#666660;--muted2:#999990;--cyan:#c8a96e;--green:#e8c98e;--amber:#f0d080;--red:#e06060;--purple:#c8a96e;--r:8px}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:'Space Grotesk',sans-serif;font-size:18px;overflow-x:hidden;min-height:100vh}
.hero{position:relative;min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:2rem;overflow:hidden;text-align:center}
.hero-bg{position:absolute;inset:0;background:radial-gradient(ellipse 70% 60% at 50% 40%, rgba(200,169,110,.05) 0%, transparent 65%),radial-gradient(ellipse 40% 50% at 80% 80%, rgba(232,201,142,.03) 0%, transparent 60%);pointer-events:none}
.hero-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(200,169,110,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(200,169,110,.04) 1px,transparent 1px);background-size:48px 48px;mask-image:radial-gradient(ellipse 80% 70% at 50% 50%,black 0%,transparent 100%)}
.hero-tag{font-family:'JetBrains Mono',monospace;font-size:17px;letter-spacing:.35em;color:var(--cyan);text-transform:uppercase;border:1px solid rgba(200,169,110,.3);padding:5px 14px;border-radius:3px;margin-bottom:2rem;display:inline-block;animation:fadeUp .5s .1s both}
.gold-divider {
  width: 60px; height: 1px;
  background: linear-gradient(90deg, transparent, var(--cyan), transparent);
  margin: 1.5rem auto;
}
.hero-title{font-family:'Rajdhani',sans-serif;font-size:clamp(3.5rem,8vw,7rem);font-weight:700;line-height:1;letter-spacing:-.01em;animation:fadeUp .6s .25s both}
.hero-title span{display:block;background:linear-gradient(135deg, #ffffff 0%, #e8c98e 60%, #c8a96e 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.hero-title small{font-size:.48em;font-weight:400;color:var(--muted2);-webkit-text-fill-color:var(--muted2);letter-spacing:.04em}
.hero-meta{margin-top:2rem;display:flex;gap:2.5rem;justify-content:center;flex-wrap:wrap;animation:fadeUp .6s .45s both}
.hero-stat-n{font-family:'Rajdhani',sans-serif;font-size:3.8rem;font-weight:700;color:var(--text);line-height:1}
.hero-stat-l{font-size:17px;color:var(--muted);letter-spacing:.12em;text-transform:uppercase;margin-top:3px}
.scroll-cue{position:absolute;bottom:1.5rem;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:8px;animation:fadeUp .5s 1s both}
.scroll-cue span{font-family:'JetBrains Mono',monospace;font-size:15px;letter-spacing:.18em;color:var(--muted);text-transform:uppercase}
.scroll-cue-line{width:1px;height:44px;background:linear-gradient(var(--cyan),transparent);animation:scrollDrop 2s ease-in-out infinite}
nav{position:sticky;top:0;z-index:200;background:rgba(8,11,16,.92);backdrop-filter:blur(16px);border-bottom:1px solid var(--line);display:flex;align-items:center;padding:0 2rem;gap:0}
.nav-brand{font-family:'Rajdhani',sans-serif;font-size:1.6rem;font-weight:700;color:var(--cyan);letter-spacing:.06em;padding:1rem 1.5rem 1rem 0;border-right:1px solid var(--line);margin-right:1.5rem;white-space:nowrap}
.nav-links{display:flex;gap:0;flex:1;overflow-x:auto}
.nav-links::-webkit-scrollbar{display:none}
.nav-link{font-family:'JetBrains Mono',monospace;font-size:15px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted2);padding:.9rem 1rem;border-bottom:2px solid transparent;cursor:pointer;background:none;border-top:none;border-left:none;border-right:none;white-space:nowrap;transition:color .2s,border-color .2s}
.nav-link:hover{color:var(--text)}
.nav-link.active{color:var(--cyan);border-bottom-color:var(--cyan)}
.brand-bar{background:var(--bg1);border-bottom:1px solid var(--line);padding:.75rem 2rem;display:flex;gap:.6rem;align-items:center;flex-wrap:wrap;position:sticky;top:53px;z-index:190}
.brand-bar-inner{display:flex;gap:1rem;align-items:center;flex-wrap:wrap;width:100%}
.filter-group{display:flex;gap:.6rem;align-items:center;flex-wrap:wrap}
.filter-group:not(:first-child){border-left:1px solid var(--line);padding-left:1rem}
.search-box{margin-left:auto;display:flex;gap:.6rem;align-items:center}
.search-input{background:var(--bg2);color:var(--text);border:1px solid var(--line2);padding:6px 12px;font-family:'JetBrains Mono',monospace;font-size:14px;border-radius:3px;width:200px;outline:none;transition:border-color .2s}
.search-input:focus{border-color:var(--cyan)}
.brand-label{font-family:'JetBrains Mono',monospace;font-size:15px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);margin-right:.3rem}
.brand-btn{font-family:'JetBrains Mono',monospace;font-size:15px;letter-spacing:.08em;text-transform:uppercase;padding:7px 18px;border-radius:3px;border:1px solid var(--line2);background:transparent;color:var(--muted2);cursor:pointer;transition:all .15s;white-space:nowrap}
.brand-btn:hover{color:var(--text)}
.brand-btn.active{font-weight:600;background:var(--cyan);color:#000}
.brand-dot{width:7px;height:7px;border-radius:50%;display:inline-block;margin-right:5px;vertical-align:middle}
main{padding:3rem 2rem;max-width:1440px;margin:0 auto}
.section{margin-bottom:4rem}
.section-header{display:flex;align-items:flex-end;gap:1rem;margin-bottom:1.5rem;padding-bottom:1rem;border-bottom:1px solid var(--line);flex-wrap:wrap}
.section-idx{font-family:'JetBrains Mono',monospace;font-size:16px;color:var(--cyan);letter-spacing:.14em}
.section-name{font-family:'Rajdhani',sans-serif;font-size:2.8rem;font-weight:700;letter-spacing:-.01em;line-height:1}
.section-sub{margin-left:auto;font-size:16px;color:var(--muted);text-align:right;max-width:280px}
.tile-grid{display:grid;gap:1rem}
.tile-grid-2{grid-template-columns:repeat(auto-fit,minmax(360px,1fr))}
.tile{background:var(--bg1);border:1px solid var(--line);border-radius:var(--r);overflow:hidden;transition:border-color .2s,transform .15s}
.tile:hover{border-color:var(--line2);transform:translateY(-1px)}
.tile-head{display:flex;align-items:center;justify-content:space-between;padding:.85rem 1.1rem .7rem;border-bottom:1px solid var(--line);gap:.5rem}
.tile-title{font-family:'Rajdhani',sans-serif;font-size:1.4rem;font-weight:600;letter-spacing:.04em;display:flex;align-items:center;gap:.5rem}
.tile-meta{font-family:'JetBrains Mono',monospace;font-size:14px;color:var(--muted);letter-spacing:.1em;text-transform:uppercase}
.tile-body{padding:1rem 1.1rem}
.bar-list{display:flex;flex-direction:column;gap:6px}
.bar-item{display:grid;grid-template-columns:22px 1fr auto;gap:.5rem 8px;align-items:center}
.bar-item-info{display:flex;flex-direction:column;min-width:0}
.bar-model{font-size:16px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;color:var(--text)}
.bar-spec{font-family:'JetBrains Mono',monospace;font-size:14px;color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-top:1px}
.bar-track{height:7px;background:var(--bg3);border-radius:3px;overflow:hidden;margin-top:4px}
.bar-fill{height:100%;border-radius:3px;transition:width .6s ease}
.bar-val{font-family:'JetBrains Mono',monospace;font-size:16px;font-weight:500;text-align:right;white-space:nowrap}
.bar-pct{font-family:'JetBrains Mono',monospace;font-size:14px;color:var(--muted);text-align:right}
.no-data{font-family:'JetBrains Mono',monospace;font-size:15px;color:var(--muted);padding:.5rem 0;text-align:center}
.rank{font-family:'Rajdhani',sans-serif;font-size:1.2rem;font-weight:700;text-align:center;color:var(--muted)}
.rank-1{color:#00d4ff}
.rank-2{color:#c8d8e8}
.rank-3{color:#ffb020}
.temp-pair{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.temp-box{background:var(--bg2);border-radius:5px;padding:.65rem .8rem}
.temp-label{font-family:'JetBrains Mono',monospace;font-size:14px;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;margin-bottom:6px}
.temp-bar-item{display:flex;align-items:center;gap:6px;margin-bottom:4px}
.temp-bar-name{font-size:13px;color:var(--muted2);width:180px;flex-shrink:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.temp-bar-track{flex:1;height:6px;background:var(--bg3);border-radius:2px;overflow:hidden}
.temp-bar-fill{height:100%;border-radius:2px;transition:width .5s ease}
.temp-val{font-family:'JetBrains Mono',monospace;font-size:15px;font-weight:500;width:50px;text-align:right}
.t-cool{background:linear-gradient(90deg,#00d4ff,#00a8d4)}
.t-warm{background:linear-gradient(90deg,#ffb020,#e07000)}
.t-hot{background:linear-gradient(90deg,#ff4560,#c01030)}
.tc-cool{color:#00d4ff}
.tc-warm{color:#ffb020}
.tc-hot{color:#ff4560}

.tbl-wrap{overflow-x:auto;border-radius:var(--r);border:1px solid var(--line);position:relative}
table{width:100%;border-collapse:separate;border-spacing:0;font-family:'JetBrains Mono',monospace;font-size:10px}
.sticky-col{position:sticky;background:var(--bg1);z-index:2}
.sticky-col-0{left:0;min-width:90px}
.sticky-col-1{left:90px;min-width:180px}
.sticky-col-2{left:270px;min-width:240px}
.sticky-col-3{left:510px;min-width:60px}
tbody tr:hover .sticky-col{background:var(--bg2)}
thead .sticky-col{z-index:3;background:var(--bg1)}


thead th{padding:11px 13px;text-align:left;border-bottom:1px solid var(--line2);color:var(--muted);letter-spacing:.08em;font-size:14px;background:var(--bg1);white-space:nowrap;cursor:pointer;user-select:none}
thead th:hover{color:var(--text)}
thead th.s-a::after{content:' ↑';color:var(--cyan)}
thead th.s-d::after{content:' ↓';color:var(--cyan)}
tbody tr{border-bottom:1px solid var(--line)}
tbody tr:hover{background:var(--bg2)}
tbody td{padding:9px 13px;white-space:nowrap;vertical-align:middle;font-size:14px}
tbody td.r{text-align:right}
tbody td.d{color:var(--muted)}
.pill{font-size:13px;letter-spacing:.07em;text-transform:uppercase;padding:2px 7px;border-radius:2px;border:1px solid;display:inline-block;font-family:'JetBrains Mono',monospace}
.compare-picker-group{margin-bottom:1.5rem;border:1px solid var(--line);border-radius:var(--r);overflow:hidden;background:var(--bg1)}
.compare-picker-brand{padding:8px 12px;font-family:'Rajdhani',sans-serif;font-size:1.2rem;font-weight:700;border-bottom:1px solid var(--line);background:var(--bg2)}
.compare-picker-series-row{display:grid;grid-template-columns:120px 1fr;border-bottom:1px solid var(--line)}
.compare-picker-series-row:last-child{border-bottom:none}
.compare-picker-series-label{padding:6px 12px;font-family:'JetBrains Mono',monospace;font-size:13px;color:var(--muted);background:var(--bg2);display:flex;align-items:center}
.compare-picker-laptops{padding:6px 12px;display:flex;flex-wrap:wrap;gap:6px;align-items:center}
@keyframes fadeUp{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)}}
@keyframes scrollDrop{0%{opacity:0}40%{opacity:1}100%{opacity:0}}

/* ── DRAG SCROLL ── */
.drag-scroll{cursor:grab;user-select:none}
.drag-scroll.dragging{cursor:grabbing}
</style>
</head>
<body>

<div class="hero">
  <div class="hero-bg"></div>
  <div class="hero-grid"></div>
  <div class="hero-tag">Gaming Laptop Performance Database 2024–2026</div>
  <h1 class="hero-title">
    <span>LAPTOP</span>
    <span>BENCHMARK</span>
    <small>Real Data · No Filler</small>
  </h1>
  <div class="hero-meta">
    <div class="hero-stat"><div class="hero-stat-n" id="s-n">—</div><div class="hero-stat-l">Laptops</div></div>
    <div class="hero-stat"><div class="hero-stat-n" id="s-b">5</div><div class="hero-stat-l">Brands</div></div>
    <div class="hero-stat"><div class="hero-stat-n" id="s-ts">—</div><div class="hero-stat-l">Best Time Spy</div></div>
    <div class="hero-stat"><div class="hero-stat-n" id="s-bat">—</div><div class="hero-stat-l">Best Battery</div></div>
  </div>
  <div class="scroll-cue"><span>Explore below</span><div class="scroll-cue-line"></div></div>
</div>

<nav>
  <div class="nav-brand">BENCHMARK</div>
  <div class="nav-links">
    <button class="nav-link active" onclick="goTo('gpu')">GPU</button>
    <button class="nav-link" onclick="goTo('cpu')">CPU</button>
    <button class="nav-link" onclick="goTo('battery')">Battery</button>
    <button class="nav-link" onclick="goTo('thermals')">Thermals</button>
    <button class="nav-link" onclick="goTo('pcmark')">PCMark 10</button>
    <button class="nav-link" onclick="goTo('compare')">Compare</button>
    <button class="nav-link" onclick="goTo('tbl')">Full Data</button>
  </div>
</nav>

<div class="brand-bar">
  <div class="brand-bar-inner">
    <div class="filter-group">
      <span class="brand-label">Brand ·</span>
      <button class="brand-btn active" data-b="ALL" onclick="setBrand('ALL',this)">All</button>
      <button class="brand-btn" data-b="ASUS" onclick="setBrand('ASUS',this)"><span class="brand-dot" style="background:#00d4ff"></span>ASUS</button>
      <button class="brand-btn" data-b="Acer" onclick="setBrand('Acer',this)"><span class="brand-dot" style="background:#ff4560"></span>Acer</button>
      <button class="brand-btn" data-b="Lenovo" onclick="setBrand('Lenovo',this)"><span class="brand-dot" style="background:#ffb020"></span>Lenovo</button>
      <button class="brand-btn" data-b="HP" onclick="setBrand('HP',this)"><span class="brand-dot" style="background:#a78bfa"></span>HP</button>
      <button class="brand-btn" data-b="Gigabyte" onclick="setBrand('Gigabyte',this)"><span class="brand-dot" style="background:#39ff84"></span>Gigabyte</button>
    </div>
    <div class="filter-group">
      <span class="brand-label">Year ·</span>
      <button class="brand-btn active" data-y="ALL" onclick="setYear('ALL',this)">All</button>
      <button class="brand-btn" data-y="2024" onclick="setYear('2024',this)">2024</button>
      <button class="brand-btn" data-y="2025" onclick="setYear('2025',this)">2025</button>
      <button class="brand-btn" data-y="2026" onclick="setYear('2026',this)">2026</button>
    </div>
    <div class="filter-group">
      <span class="brand-label">Series ·</span>
      <select id="series-filter" onchange="setSeries(this.value)" style="background:var(--bg2);color:var(--text);border:1px solid var(--line2);padding:5px;font-family:'JetBrains Mono',monospace;font-size:14px;border-radius:3px;cursor:pointer;outline:none">
        <option value="ALL">All Series</option>
      </select>
    </div>
    <div class="search-box">
      <input type="text" id="global-search" oninput="setSearch(this.value)" placeholder="Search model, spec..." class="search-input">
      <button class="brand-btn" onclick="clearFilters()" style="font-size:12px;">Clear Filters</button>
    </div>
  </div>
</div>

<main>
<div class="section" id="gpu">
  <div class="section-header">
    <span class="section-idx">01 —</span>
    <h2 class="section-name">GPU Benchmark / 3DMark</h2>
    <span class="section-sub">Higher score = better GPU · Percentage vs top score</span>
  </div>
  <div class="tile-grid tile-grid-2" id="gpu-grid"></div>
</div>

<div class="section" id="cpu">
  <div class="section-header">
    <span class="section-idx">02 —</span>
    <h2 class="section-name">CPU Test / Cinebench</h2>
    <span class="section-sub">Higher = faster CPU processing</span>
  </div>
  <div class="tile-grid tile-grid-2" id="cpu-grid"></div>
</div>

<div class="section" id="battery">
  <div class="section-header">
    <span class="section-idx">03 —</span>
    <h2 class="section-name">Battery Test</h2>
    <span class="section-sub">Social + YouTube usage · Standby hours</span>
  </div>
  <div class="tile-grid tile-grid-2" id="battery-grid"></div>
</div>

<div class="section" id="thermals">
  <div class="section-header">
    <span class="section-idx">04 —</span>
    <h2 class="section-name">Cooling Test / Thermals</h2>
    <span class="section-sub">Turbo mode · Room 25°C avg · Lower = cooler</span>
  </div>
  <div class="tile-grid tile-grid-2" id="thermal-grid"></div>
</div>

<div class="section" id="pcmark">
  <div class="section-header">
    <span class="section-idx">05 —</span>
    <h2 class="section-name">PCMark 10 / Extended</h2>
    <span class="section-sub">Real-world productivity benchmark</span>
  </div>
  <div class="tile-grid tile-grid-2" id="pcmark-grid"></div>
</div>


<div class="section" id="compare">
  <div class="section-header">
    <span class="section-idx">06 —</span>
    <h2 class="section-name">Direct Comparison</h2>
    <span class="section-sub">Select up to 6 laptops to compare side by side · <span id="compare-count">0 selected</span></span>
  </div>
  <div id="compare-picker" style="display:flex;flex-wrap:wrap;gap:.5rem;margin-bottom:1.5rem"></div>
  <div id="compare-result" class="tbl-wrap" style="display:none">
    <table id="compare-table">
      <thead id="compare-thead"></thead>
      <tbody id="compare-tbody"></tbody>
    </table>
  </div>
</div>

<div class="section" id="tbl">
  <div class="section-header">
    <span class="section-idx">07 —</span>
    <h2 class="section-name">Full Benchmark Data</h2>
    <span class="section-sub">Click headers to sort · Exact CSV values only</span>
  </div>
  <div class="tbl-wrap"><table>
    <thead><tr>
      <th onclick="srt('brand')" class="sticky-col sticky-col-0">Brand</th>
      <th onclick="srt('model')" class="sticky-col sticky-col-1">Model</th>
      <th onclick="srt('spec')" class="sticky-col sticky-col-2">Spec</th>
      <th onclick="srt('year')" class="r sticky-col sticky-col-3">Year</th>
      <th onclick="srt('timeSpy')" class="r s-d">Time Spy</th>
      <th onclick="srt('tsExtreme')" class="r">TS Extreme</th>
      <th onclick="srt('fsExt')" class="r">FS Extreme</th>
      <th onclick="srt('fsUltra')" class="r">FS Ultra</th>
      <th onclick="srt('steelNomad')" class="r">Steel Nomad</th>
      <th onclick="srt('cbR23S')" class="r">R23 Single</th>
      <th onclick="srt('cbR23M')" class="r">R23 Multi</th>
      <th onclick="srt('cbR24S')" class="r">R24 Single</th>
      <th onclick="srt('cbR24M')" class="r">R24 Multi</th>
      <th onclick="srt('battery')" class="r">Battery</th>
      <th onclick="srt('standby')" class="r">Standby</th>
      <th onclick="srt('cpuIdle')" class="r">CPU Idle</th>
      <th onclick="srt('cpuLoad')" class="r">CPU Load</th>
      <th onclick="srt('gpuIdle')" class="r">GPU Idle</th>
      <th onclick="srt('gpuLoad')" class="r">GPU Load</th>
    </tr></thead>
    <tbody id="tbl-body"></tbody>
  </table></div>
</div>
</main>

<footer style="border-top:1px solid var(--line);padding:1.5rem 2rem;text-align:center;font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--muted);letter-spacing:.1em">
  LAPTOP BENCHMARK · Data from Google Sheets CSV · 2024–2026 · All values are exact — blanks/dashes preserved
</footer>

<script>

const BC={ASUS:'#00d4ff',Acer:'#ff4560',Lenovo:'#ffb020',HP:'#a78bfa',Gigabyte:'#39ff84'};
const bc=b=>BC[b]||'#8899b0';
const getKey=l=>`${l.brand}|${l.model}|${l.spec}`;
const N=v=>v!=null&&v!==''&&!isNaN(v)?Number(v):null;
const fmt=(v,d=0)=>v!=null?v.toLocaleString('en-US',{maximumFractionDigits:d}):'—';
const pct=(v,mx)=>mx?Math.round((v/mx)*100):0;
const tcls=v=>v==null?'':v<60?'tc-cool':v<85?'tc-warm':'tc-hot';
const tbcls=v=>v==null?'t-cool':v<60?'t-cool':v<85?'t-warm':'t-hot';

const D=[
  {
    "brand": "ASUS",
    "series": "ROG",
    "model": "ROG Strix Scar 18",
    "spec": "Core Ultra 9 275HX + RTX 5090 175W",
    "year": 2025,
    "timeSpy": 22882.0,
    "tsGfx": 24315.0,
    "tsExtreme": 11846.0,
    "tsExtremeGfx": 11925.0,
    "fsExt": 26919.0,
    "fsExtGfx": 29157.0,
    "fsExtPhys": 45105.0,
    "fsUltra": 14817.0,
    "fsUltraGfx": 14210.0,
    "fsUltraPhys": 45890.0,
    "steelNomad": 6094.0,
    "cbR23S": 2221.0,
    "cbR23M": 38002.0,
    "cbR24S": 135.0,
    "cbR24M": 2013.0,
    "battery": 4.24,
    "standby": 5.0,
    "pcmark": 11019.0,
    "pcEss": 10444.0,
    "pcProd": 11299.0,
    "pcCC": 13987.0,
    "pcGaming": 24151.0,
    "cpuIdle": 43.0,
    "cpuLoad": 105.0,
    "gpuIdle": 45.0,
    "gpuLoad": 76.0
  },
  {
    "brand": "ASUS",
    "series": "ROG",
    "model": "ROG Zephyrus DUO",
    "spec": "Core Ultra 9 386H + RTX 5090 150W",
