let activeBrand='ALL';
let activeYear='ALL';
let activeSeries='ALL';
let activeSearch='';

const getData=()=>{
  return D.filter(l=>{
    const matchBrand = activeBrand==='ALL' || l.brand===activeBrand;
    const matchYear = activeYear==='ALL' || l.year?.toString()===activeYear;
    const matchSeries = activeSeries==='ALL' || l.series===activeSeries;
    const matchSearch = activeSearch==='' ||
      [l.model, l.spec, l.brand, l.series].some(field =>
        field?.toLowerCase().includes(activeSearch.toLowerCase())
      );
    return matchBrand && matchYear && matchSeries && matchSearch;
  });
};
const getF=k=>getData().filter(l=>l[k]!=null).sort((a,b)=>b[k]-a[k]);

// ── COMPARE (defined first so renderAll can call it) ──
const COMPARE_MAX=6;
let compareSet=new Set();

function renderComparePicker(){
  const d=getData();
  const container=document.getElementById('compare-picker');
  if(!container)return;

  const groups={};
  d.forEach(l=>{
    if(!groups[l.brand])groups[l.brand]={};
    if(!groups[l.brand][l.series])groups[l.brand][l.series]=[];
    groups[l.brand][l.series].push(l);
  });

  let html='';
  for(const brand in groups){
    const brandColor=bc(brand);
    html+=`<div class="compare-picker-group">
      <div class="compare-picker-brand" style="color:${brandColor}">${brand}</div>`;

    for(const series in groups[brand]){
      html+=`<div class="compare-picker-series-row">
        <div class="compare-picker-series-label">${series}</div>
        <div class="compare-picker-laptops">`;

      html+=groups[brand][series].map(l=>{
        const key=getKey(l);
        const sel=compareSet.has(key);
        const c=bc(l.brand);
        return `<button onclick="toggleCompare('${key.replace(/'/g, "\\'")}')" style="font-family:'JetBrains Mono',monospace;font-size:12px;padding:5px 14px;border-radius:3px;cursor:pointer;transition:all .15s;border:1px solid ${sel?c:'var(--line2)'};background:${sel?c+'22':'transparent'};color:${sel?c:'var(--muted2)'};font-weight:${sel?'600':'400'};margin:2px">${l.model}</button>`;
      }).join('');

      html+=`</div></div>`;
    }
    html+=`</div>`;
  }

  container.innerHTML=html||'<div class="no-data">No laptops match filters</div>';
  document.getElementById('compare-count').textContent=compareSet.size+' / 6 selected';
}

function toggleCompare(key){
  if(compareSet.has(key)){compareSet.delete(key);}
  else{if(compareSet.size>=COMPARE_MAX)return;compareSet.add(key);}
  renderComparePicker();
  renderCompareTable();
}

function renderCompareTable(){
  const result=document.getElementById('compare-result');
  if(!result)return;
  if(compareSet.size===0){result.style.display='none';return;}
  result.style.display='';
  const sel=[...compareSet].map(k=>D.find(l=>getKey(l)===k)).filter(Boolean);
  const rows=[
    {label:'Brand',          fn:l=>l.brand,        dir:null},
    {label:'Spec',           fn:l=>l.spec,         dir:null},
    {label:'Year',           fn:l=>l.year||'—',    dir:null},
    {label:'Time Spy',       fn:l=>l.timeSpy,      dir:'high'},
    {label:'TS Extreme',     fn:l=>l.tsExtreme,    dir:'high'},
    {label:'FS Extreme',     fn:l=>l.fsExt,        dir:'high'},
    {label:'FS Ultra',       fn:l=>l.fsUltra,      dir:'high'},
    {label:'Steel Nomad',    fn:l=>l.steelNomad,   dir:'high'},
    {label:'CB R23 Multi',   fn:l=>l.cbR23M,       dir:'high'},
    {label:'CB R23 Single',  fn:l=>l.cbR23S,       dir:'high'},
    {label:'CB R24 Multi',   fn:l=>l.cbR24M,       dir:'high'},
    {label:'CB R24 Single',  fn:l=>l.cbR24S,       dir:'high'},
    {label:'Battery (h)',    fn:l=>l.battery,      dir:'high',dec:2,unit:'h'},
    {label:'Standby (h)',    fn:l=>l.standby,      dir:'high',dec:2,unit:'h'},
    {label:'CPU Idle °C',    fn:l=>l.cpuIdle,      dir:'low', unit:'°C'},
    {label:'CPU Load °C',    fn:l=>l.cpuLoad,      dir:'low', unit:'°C'},
    {label:'GPU Idle °C',    fn:l=>l.gpuIdle,      dir:'low', unit:'°C'},
    {label:'GPU Load °C',    fn:l=>l.gpuLoad,      dir:'low', unit:'°C'},
    {label:'PCMark 10',      fn:l=>l.pcmark,       dir:'high'},
    {label:'Essentials',     fn:l=>l.pcEss,        dir:'high'},
    {label:'Productivity',   fn:l=>l.pcProd,       dir:'high'},
    {label:'Content Creation',fn:l=>l.pcCC,        dir:'high'},
    {label:'Gaming',         fn:l=>l.pcGaming,     dir:'high'},
  ];


  const fmtV=(v,row)=>{
    if(v==null)return'—';
    if(typeof v==='string')return v;
    const n=Number(v);
    const s=row.dec?n.toFixed(row.dec):n.toLocaleString();
    return s+(row.unit||'');
  };

  document.getElementById('compare-thead').innerHTML=
    '<tr>'+
    '<th class="sticky-col sticky-col-0" style="padding:10px 16px;color:var(--muted);font-family:\'JetBrains Mono\',monospace;font-size:14px;text-align:left;background:var(--bg1);z-index:3">Metric</th>'+
    sel.map(l=>`<th style="padding:10px 16px;color:${bc(l.brand)};font-family:'Rajdhani',sans-serif;font-size:1.3rem;font-weight:700;text-align:center;min-width:200px">${l.model}<br><span style="font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:400;color:var(--muted)">${l.spec}</span></th>`).join('')+
    '</tr>';

  document.getElementById('compare-tbody').innerHTML=rows.map(row=>{
    const vals=sel.map(l=>row.fn(l));
    // Parse numeric values
    const nums=vals.map(v=>typeof v==='number'?v:(typeof v==='string'?parseFloat(v.replace(/[^0-9.]/g,'')):NaN));
    const validNums=nums.filter(n=>!isNaN(n));

    // Find best value index
    let bestIdx=-1;
    if(row.dir && validNums.length>1){
      const bv=row.dir==='high'?Math.max(...validNums):Math.min(...validNums);
      bestIdx=nums.findIndex(n=>n===bv);
    }

    // Build cells
    const cells=vals.map((v,i)=>{
      const isBest=i===bestIdx;
      const disp=fmtV(v,row);
      const myNum=nums[i];

      // Percentage difference vs best (only if numeric row, >1 valid value, this cell has a value)
      let pctBadge='';
      if(row.dir && validNums.length>1 && !isNaN(myNum) && bestIdx!==-1 && i!==bestIdx){
        const bestNum=nums[bestIdx];
        if(bestNum!==0){
          // For 'high': how far below best? For 'low': how far above best (worse)?
          let diff;
          if(row.dir==='high'){
            diff=((myNum-bestNum)/bestNum)*100; // negative = worse
          } else {
            diff=((bestNum-myNum)/bestNum)*100; // negative = worse (myNum > bestNum means hotter)
          }
          const absDiff=Math.abs(diff).toFixed(1);
          if(diff<0){
            // worse than best
            pctBadge=`<div style="margin-top:5px;font-size:14px;font-weight:600;color:#ff4560">▼ ${absDiff}%</div>`;
          } else {
            // equal or better (shouldn't happen for non-best but guard)
            pctBadge=`<div style="margin-top:5px;font-size:14px;font-weight:600;color:#39ff84">▲ ${absDiff}%</div>`;
          }
        }
      } else if(row.dir && validNums.length>1 && !isNaN(myNum) && i===bestIdx){
        // Best cell — show crown indicator only if more than one valid
        pctBadge=`<div style="margin-top:5px;font-size:13px;color:#39ff84;font-weight:600">▲ Best ✦</div>`;
      }

      return `<td style="padding:10px 16px;text-align:center;font-family:'JetBrains Mono',monospace;font-size:16px;color:${isBest?'var(--cyan)':'var(--text)'};background:${isBest?'rgba(0,212,255,0.07)':'transparent'};font-weight:${isBest?'700':'400'};vertical-align:top">${disp}${pctBadge}</td>`;
    }).join('');

    return `<tr style="border-bottom:1px solid var(--line)">
      <td class="sticky-col sticky-col-0" style="padding:10px 16px;color:var(--muted);font-family:'JetBrains Mono',monospace;font-size:14px;white-space:nowrap;background:var(--bg1);vertical-align:middle">${row.label}</td>
      ${cells}
    </tr>`;
  }).join('');
}
function setBrand(b,btn){
  activeBrand=b;
  document.querySelectorAll('.brand-btn[data-b]').forEach(x=>{x.classList.remove('active');x.style.background='';x.style.borderColor='';x.style.color='';});
  btn.classList.add('active');
  if(b!=='ALL'){btn.style.background=bc(b);btn.style.borderColor=bc(b);btn.style.color='#000';}
  else{btn.style.background='var(--text)';btn.style.borderColor='var(--text)';btn.style.color='#000';}
  renderAll();
}

function setYear(y,btn){
  activeYear=y;
  document.querySelectorAll('.brand-btn[data-y]').forEach(x=>{x.classList.remove('active');});
  btn.classList.add('active');
  renderAll();
}

function setSeries(s){
  activeSeries=s;
  renderAll();
}

function setSearch(q){
  activeSearch=q;
  renderAll();
}

function clearFilters(){
  activeBrand='ALL';
  activeYear='ALL';
  activeSeries='ALL';
  activeSearch='';
  document.getElementById('global-search').value='';
  document.getElementById('series-filter').value='ALL';
  document.querySelectorAll('.brand-btn').forEach(btn=>{
    btn.classList.remove('active');
    btn.style.background='';
    btn.style.borderColor='';
    btn.style.color='';
  });
  // Reset All buttons (Brand and Year)
  document.querySelector('.brand-btn[data-b="ALL"]').classList.add('active');
  const allB = document.querySelector('.brand-btn[data-b="ALL"]');
  allB.style.background='var(--text)';
  allB.style.borderColor='var(--text)';
  allB.style.color='#000';

  document.querySelector('.brand-btn[data-y="ALL"]').classList.add('active');

  renderAll();
}

function barHTML(data,key,limit=20){
  const vis=data.slice(0,limit);
  if(!vis.length)return'<div class="no-data">No data for this filter</div>';
  const mx=vis[0][key]||1;
  return'<div class="bar-list">'+vis.map((l,i)=>{
    const v=l[key],p=pct(v,mx),c=bc(l.brand);
    const rk=i===0?'rank-1':i===1?'rank-2':i===2?'rank-3':'';
    return`<div class="bar-item">
      <span class="rank ${rk}">${i+1}</span>
      <div class="bar-item-info">
        <div class="bar-model">${l.model}</div>
        <div class="bar-spec">${l.spec}</div>
        <div class="bar-track"><div class="bar-fill" style="width:${p}%;background:${c}"></div></div>
      </div>
      <div><div class="bar-val" style="color:${c}">${fmt(v)}</div><div class="bar-pct">${p}%</div></div>
    </div>`;}).join('')+'</div>';
}

function tile(title,icon,meta,body){
  return`<div class="tile">
    <div class="tile-head">
      <div class="tile-title"><span>${icon}</span>${title}</div>
      <span class="tile-meta">${meta}</span>
    </div>
    <div class="tile-body">${body}</div>
  </div>`;
}

function renderGPU(){
  const cfgs=[
    {k:'timeSpy',    t:'Time Spy',           i:'🎮',m:'3DMark · Higher = better'},
    {k:'tsExtreme',  t:'Time Spy Extreme',    i:'⚡',m:'3DMark · Higher = better'},
    {k:'fsExt',      t:'Fire Strike Extreme', i:'🔥',m:'3DMark · Higher = better'},
    {k:'fsUltra',    t:'Fire Strike Ultra',   i:'💠',m:'3DMark · Higher = better'},
    {k:'steelNomad', t:'Steel Nomad',         i:'🗡️',m:'3DMark DX12 · Higher = better'},
  ];
  document.getElementById('gpu-grid').innerHTML=cfgs.map(c=>tile(c.t,c.i,c.m,barHTML(getF(c.k),c.k))).join('');
}

function renderCPU(){
  const cfgs=[
    {k:'cbR23M',t:'Cinebench R23 Multi-Core', i:'🧠',m:'Higher = faster multi-thread'},
    {k:'cbR23S',t:'Cinebench R23 Single-Core',i:'🧵',m:'Higher = faster single-thread'},
    {k:'cbR24M',t:'Cinebench R24 Multi-Core', i:'⚙️',m:'Newer · Higher = better'},
    {k:'cbR24S',t:'Cinebench R24 Single-Core',i:'🔩',m:'Newer · Higher = better'},
  ];
  document.getElementById('cpu-grid').innerHTML=cfgs.map(c=>tile(c.t,c.i,c.m,barHTML(getF(c.k),c.k))).join('');
}

function renderBattery(){
  function battBar(data,key,color){
    const vis=data.slice(0,25);
    if(!vis.length)return'<div class="no-data">No data</div>';
    const mx=vis[0][key]||1;
    return'<div class="bar-list">'+vis.map((l,i)=>{
      const v=l[key],p=pct(v,mx);
      const rk=i===0?'rank-1':i===1?'rank-2':i===2?'rank-3':'';
      return`<div class="bar-item">
        <span class="rank ${rk}">${i+1}</span>
        <div class="bar-item-info">
          <div class="bar-model">${l.model}</div>
          <div class="bar-spec">${l.spec}</div>
          <div class="bar-track"><div class="bar-fill" style="width:${p}%;background:${color}"></div></div>
        </div>
        <div><div class="bar-val" style="color:${color}">${v.toFixed(2)}h</div><div class="bar-pct">${p}%</div></div>
      </div>`;}).join('')+'</div>';
  }
  document.getElementById('battery-grid').innerHTML=
    tile('Social + YouTube Usage','🔋','Hours · Higher = better',battBar(getF('battery'),'battery','#39ff84'))+
    tile('Standby Mode','💤','Hours · Higher = better',battBar(getF('standby'),'standby','#20e870'));
}

function renderThermals(){
  function tempTile(title,icon,idleK,loadK){
    const idleData=getData().filter(l=>l[idleK]!=null).sort((a,b)=>a[idleK]-b[idleK]);
    const loadData=getData().filter(l=>l[loadK]!=null).sort((a,b)=>a[loadK]-b[loadK]);
    if(!idleData.length&&!loadData.length)return tile(title,icon,'°C · Lower = cooler','<div class="no-data">No data</div>');
    const mxI=Math.max(...idleData.map(l=>l[idleK]),1);
    const mxL=Math.max(...loadData.map(l=>l[loadK]),1);
    const rows=(arr,k,mx)=>arr.slice(0,15).map(l=>{
      const v=l[k],p=pct(v,mx);
      return`<div class="temp-bar-item">
        <div class="temp-bar-name" title="${l.model}">${l.model}</div>
        <div class="temp-bar-track"><div class="temp-bar-fill ${tbcls(v)}" style="width:${p}%"></div></div>
        <div class="temp-val ${tcls(v)}">${v}°C</div>
      </div>`;}).join('');
    const body=`<div class="temp-pair">
      <div class="temp-box"><div class="temp-label">💤 Idle (coolest first)</div>${rows(idleData,idleK,mxI)}</div>
      <div class="temp-box"><div class="temp-label">🔥 Full Load (coolest first)</div>${rows(loadData,loadK,mxL)}</div>
    </div>`;
    return tile(title,icon,'°C · Lower = cooler',body);
  }
  document.getElementById('thermal-grid').innerHTML=
    tempTile('CPU Temperature','🧠','cpuIdle','cpuLoad')+
    tempTile('GPU Temperature','🎮','gpuIdle','gpuLoad');
}

function renderPCMark(){
  const cfgs=[
    {k:'pcmark', t:'PCMark 10 Overall',   i:'📊',m:'Extended score'},
    {k:'pcEss',  t:'Essentials',           i:'💼',m:'Web · Video · App launch'},
    {k:'pcProd', t:'Productivity',         i:'📝',m:'Spreadsheet · Writing'},
    {k:'pcCC',   t:'Content Creation',     i:'🎨',m:'Photo & video editing'},
    {k:'pcGaming',t:'Gaming',              i:'🕹️',m:'In-game performance'},
  ];
  document.getElementById('pcmark-grid').innerHTML=cfgs.map(c=>tile(c.t,c.i,c.m,barHTML(getF(c.k),c.k))).join('');
}

let sKey='timeSpy',sDir=-1;
function srt(k){
  if(sKey===k)sDir*=-1;else{sKey=k;sDir=-1;}
  document.querySelectorAll('thead th').forEach(th=>{
    const ok=th.getAttribute('onclick')==='srt(\''+k+'\')';
    const base=th.className.replace(/\bs-[ad]\b/g,'').trim();
    th.className=ok?base+' '+(sDir===-1?'s-d':'s-a'):base;
  });
  renderTable();
}

function tclr(v){if(v==null)return'';return v<60?'color:#00d4ff':v<85?'color:#ffb020':'color:#ff4560';}

function renderTable(){
  const data=[...getData()].sort((a,b)=>{
    const va=a[sKey]??-Infinity,vb=b[sKey]??-Infinity;
    if(typeof va==='string')return sDir*va.localeCompare(vb);
    return sDir*(vb-va);
  });
  const c=br=>`color:${bc(br)};border-color:${bc(br)}44`;
  document.getElementById('tbl-body').innerHTML=data.map(l=>`<tr>
    <td class="sticky-col sticky-col-0"><span class="pill" style="${c(l.brand)}">${l.brand}</span></td>
    <td class="sticky-col sticky-col-1">${l.model}</td>
    <td class="sticky-col sticky-col-2 d">${l.spec}</td>
    <td class="r d sticky-col sticky-col-3">${l.year||'—'}</td>
    <td class="r">${fmt(l.timeSpy)}</td>
    <td class="r d">${fmt(l.tsExtreme)}</td>
    <td class="r d">${fmt(l.fsExt)}</td>
    <td class="r d">${fmt(l.fsUltra)}</td>
    <td class="r d">${fmt(l.steelNomad)}</td>
    <td class="r d">${fmt(l.cbR23S)}</td>
    <td class="r">${fmt(l.cbR23M)}</td>
    <td class="r d">${fmt(l.cbR24S)}</td>
    <td class="r d">${fmt(l.cbR24M)}</td>
    <td class="r" style="color:${l.battery?'#39ff84':'inherit'}">${l.battery!=null?l.battery.toFixed(2)+'h':'—'}</td>
    <td class="r d">${l.standby!=null?l.standby.toFixed(2)+'h':'—'}</td>
    <td class="r" style="${tclr(l.cpuIdle)}">${l.cpuIdle!=null?l.cpuIdle+'°C':'—'}</td>
    <td class="r" style="${tclr(l.cpuLoad)}">${l.cpuLoad!=null?l.cpuLoad+'°C':'—'}</td>
    <td class="r" style="${tclr(l.gpuIdle)}">${l.gpuIdle!=null?l.gpuIdle+'°C':'—'}</td>
    <td class="r" style="${tclr(l.gpuLoad)}">${l.gpuLoad!=null?l.gpuLoad+'°C':'—'}</td>
  </tr>`).join('');
}

function updateHero(){
  const d=getData();
  const ts=d.filter(l=>l.timeSpy!=null);
  const bt=d.filter(l=>l.battery!=null);
  document.getElementById('s-n').textContent=d.length;
  document.getElementById('s-b').textContent=[...new Set(d.map(l=>l.brand))].length;
  document.getElementById('s-ts').textContent=ts.length?Math.max(...ts.map(l=>l.timeSpy)).toLocaleString():'—';
  document.getElementById('s-bat').textContent=bt.length?Math.max(...bt.map(l=>l.battery)).toFixed(2)+'h':'—';
}

function initSeriesFilter(){
  const series = [...new Set(D.map(l=>l.series))].filter(Boolean).sort();
  const sel = document.getElementById('series-filter');
  if(!sel) return;
  const currentVal = sel.value;
  sel.innerHTML = '<option value="ALL">All Series</option>' +
    series.map(s=>`<option value="${s}">${s}</option>`).join('');
  sel.value = currentVal;
}

function renderAll(){
  updateHero();
  renderGPU();
  renderCPU();
  renderBattery();
  renderThermals();
  renderPCMark();
  renderTable();
  compareSet=new Set();
  renderComparePicker();
  renderCompareTable();
}

initSeriesFilter();
renderAll();

const NAV=['gpu','cpu','battery','thermals','pcmark','compare','tbl'];
window.addEventListener('scroll',()=>{
  const tabs=document.querySelectorAll('.nav-link');
  let a=0;NAV.forEach((id,i)=>{const el=document.getElementById(id);if(el&&window.scrollY>=el.offsetTop-120)a=i;});
  tabs.forEach((t,i)=>t.classList.toggle('active',i===a));
},{passive:true});
function goTo(id){document.getElementById(id).scrollIntoView({behavior:'smooth',block:'start'})}


// ── DRAG TO SCROLL ──
function enableDragScroll(el){
  if(!el||el._dragEnabled)return;
  el._dragEnabled=true;
  let isDown=false,startX=0,scrollLeft=0;
  el.addEventListener('mousedown',e=>{
    if(e.target.tagName==='BUTTON'||e.target.tagName==='TH')return;
    isDown=true;
    el.classList.add('dragging');
    startX=e.pageX;
    scrollLeft=el.scrollLeft;
    e.preventDefault();
  });
  window.addEventListener('mouseup',()=>{isDown=false;el.classList.remove('dragging');});
  el.addEventListener('mousemove',e=>{
    if(!isDown)return;
    el.scrollLeft=scrollLeft-(e.pageX-startX)*1.2;
  });
  let tX=0,tSL=0;
  el.addEventListener('touchstart',e=>{tX=e.touches[0].pageX;tSL=el.scrollLeft;},{passive:true});
  el.addEventListener('touchmove',e=>{el.scrollLeft=tSL-(e.touches[0].pageX-tX);},{passive:true});
}

function applyDragScrolls(){
  const tbl=document.querySelector('#tbl .tbl-wrap');
  if(tbl){tbl.classList.add('drag-scroll');enableDragScroll(tbl);}
  const cmp=document.querySelector('#compare-tile .tile-body');
  if(cmp){cmp.classList.add('drag-scroll');enableDragScroll(cmp);}
}

const _origRenderTable=renderTable;
renderTable=function(){_origRenderTable();setTimeout(()=>{const t=document.querySelector('#tbl .tbl-wrap');if(t){t.classList.add('drag-scroll');enableDragScroll(t);}},0);};

const _origRenderCompareTable=renderCompareTable;
renderCompareTable=function(){_origRenderCompareTable();setTimeout(()=>{const c=document.querySelector('#compare-result');if(c){c.classList.add('drag-scroll');enableDragScroll(c);}},0);};

// init on load
setTimeout(applyDragScrolls,200);
</script>
</body>
</html>
